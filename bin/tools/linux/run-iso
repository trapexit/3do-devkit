#!/bin/sh

if which flatpak >/dev/null 2>&1; then
    flatpak run org.libretro.RetroArch --verbose -L opera_libretro.so "$@"
elif which retroarch >/dev/null 2>&1; then
    retroarch --verbose -L opera_libretro.so "$@"
else
    echo "Unable to find RetroArch. Install via flatpak or your package manager."
    exit 1
fi
